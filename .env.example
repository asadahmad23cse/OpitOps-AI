# Copy to .env.local and fill in keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Groq (AI Assistant) — https://console.groq.com
GROQ_API_KEY=

# GitHub (deployments feed) — fine-grained or classic PAT with read access to repos
GITHUB_TOKEN=
GITHUB_OWNER=
